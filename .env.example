# ── LLM (해설 생성 / 글로서리 추출) ─────────────────────────────
# provider: openai-compat | anthropic | mock
# - openai-compat : OpenAI 및 호환 엔드포인트. LLM_API_KEY(또는 OPENAI_API_KEY) 사용
# - anthropic     : ANTHROPIC_API_KEY 필요 (기본 모델 claude-sonnet-4-6)
# - mock          : LLM 호출 없이 글로서리/근거만으로 응답 (키 없이 데모 가능)
LLM_PROVIDER=openai-compat
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
# anthropic 사용 시
ANTHROPIC_API_KEY=

# ── 임베딩 (세그먼트/글로서리 인덱스) ────────────────────────────
# provider: openai | voyage | local
# - openai : OPENAI_API_KEY 필요 (기본 모델 text-embedding-3-small)
# - voyage : VOYAGE_API_KEY 필요 (기본 모델 voyage-3.5-lite)
# - local  : 문자 n-gram 해시 임베딩 (키 불필요 폴백)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
VOYAGE_API_KEY=
